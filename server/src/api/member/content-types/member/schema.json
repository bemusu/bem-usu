{
  "kind": "collectionType",
  "collectionName": "members",
  "info": {
    "singularName": "member",
    "pluralName": "members",
    "displayName": "Member"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "position": {
      "type": "enumeration",
      "required": true,
      "default": "Staff",
      "enum": [
        "Ketua BEM",
        "Wakil Ketua BEM",
        "Kepala Staff BEM",
        "Sekretaris Kabinet",
        "Sekretaris BEM",
        "Bendahara Umum",
        "Wakil Bendahara Umum",
        "Koordinator",
        "Sekretaris Koordinator",
        "Kepala Departemen",
        "Sekretaris Departemen",
        "Staff"
      ]
    },
    "department": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::department.department"
    }
  }
}
